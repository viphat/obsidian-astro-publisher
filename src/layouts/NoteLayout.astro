---
import BaseLayout from "./BaseLayout.astro";
import NoteMeta from "../components/NoteMeta.astro";
import { getTagPath } from "../lib/slug";

type Props = {
  title: string;
  description?: string;
  slug: string;
  createdAt: string;
  updatedAt: string;
  tags?: string[];
  coverImage?: string;
  language?: string;
  readMinutes?: number;
};

const {
  title,
  description,
  slug,
  createdAt,
  updatedAt,
  tags = [],
  coverImage,
  language = "en",
  readMinutes
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  pathname={`/${slug}`}
  image={coverImage}
  isNote
  lang={language}
  variant="note"
>
  <article class="note">
    <a class="note-back" href="/">&larr; All notes</a>
    <header class="note-head">
      {tags.length > 0 && (
        <ul class="note-tags" aria-label="Tags">
          {tags.map((tag) => (
            <li>
              <a href={getTagPath(tag)}>{tag}</a>
            </li>
          ))}
        </ul>
      )}
      <h1 lang={language}>{title}</h1>
      <NoteMeta createdAt={createdAt} updatedAt={updatedAt} readMinutes={readMinutes} />
      {coverImage && <img class="note-cover" src={coverImage} alt="" />}
    </header>
    <div class="note-body-card">
      <div class="note-body" lang={language}>
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .note-back {
    display: inline-flex;
    align-items: center;
    font-size: var(--step-small);
    font-weight: 600;
    color: var(--leaf);
    text-decoration: none;
  }

  .note-back:hover {
    color: var(--pine);
  }

  .note-head {
    margin-top: 1.25rem;
    margin-bottom: 2.5rem;
  }

  .note-tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0 0 1rem;
    padding: 0;
  }

  .note-tags a {
    display: inline-flex;
    align-items: center;
    background: var(--moss);
    color: var(--leaf);
    border-radius: 999px;
    padding: 0.35rem 0.9rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: background 160ms ease, color 160ms ease;
  }

  .note-tags a:hover {
    background: var(--leaf);
    color: #fff;
  }

  .note-head h1 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.25rem, 1.9rem + 1.5vw, 3rem);
    line-height: 1.15;
    letter-spacing: -0.015em;
    margin: 0;
    color: var(--ink);
    text-wrap: balance;
  }

  .note-cover {
    width: 100%;
    margin-top: 2rem;
    border-radius: var(--radius-img);
    border: 1px solid var(--line);
  }

  .note-body-card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-hero);
    box-shadow: var(--shadow-leafy);
    padding: 1.5rem;
  }

  @media (min-width: 48rem) {
    .note-body-card {
      padding: 2.5rem;
    }
  }
</style>
