---
import BaseLayout from "./BaseLayout.astro";
import NoteMeta from "../components/NoteMeta.astro";

type Props = {
  title: string;
  description?: string;
  slug: string;
  createdAt: string;
  updatedAt: string;
  tags?: string[];
  coverImage?: string;
  language?: string;
};

const {
  title,
  description,
  slug,
  createdAt,
  updatedAt,
  tags = [],
  coverImage,
  language = "en"
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  pathname={`/notes/${slug}`}
  image={coverImage}
  isNote
  lang={language}
  variant="note"
>
  <article class="note">
    <header class="note-head">
      <h1 lang={language}>{title}</h1>
      <NoteMeta createdAt={createdAt} updatedAt={updatedAt} tags={tags} />
      {coverImage && <img class="note-cover" src={coverImage} alt="" />}
    </header>
    <div class="note-body" lang={language}>
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .note-head {
    margin-bottom: 2.5rem;
  }

  .note-head h1 {
    font-family: var(--font-display);
    font-size: var(--step-h1);
    line-height: 1.12;
    letter-spacing: -0.015em;
    margin: 0;
    text-wrap: balance;
  }

  .note-cover {
    width: 100%;
    margin-top: 2rem;
    border-radius: var(--radius);
    border: 1px solid var(--rule);
  }
</style>
