---
import { getTagPath } from "../lib/slug";

type Props = {
  title: string;
  description?: string;
  href: string;
  updatedAt: string;
  tags?: string[];
  readMinutes?: number;
};

const { title, description, href, updatedAt, tags = [], readMinutes } = Astro.props;
---

<li class="note-card">
  <a class="note-link" href={href}>
    <span class="note-meta">
      <time datetime={updatedAt}>{updatedAt}</time>
      {readMinutes !== undefined && <span class="note-read">· {readMinutes} min read</span>}
    </span>
    <span class="note-title">{title}</span>
    {description && <span class="note-desc">{description}</span>}
  </a>
  {tags.length > 0 && (
    <ul class="note-tags" aria-label="Tags">
      {tags.map((tag) => (
        <li>
          <a class="note-tag" href={getTagPath(tag)}>{tag}</a>
        </li>
      ))}
    </ul>
  )}
</li>

<style>
  .note-card {
    list-style: none;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-leafy);
    padding: 1.5rem;
    transition: transform 160ms ease, box-shadow 160ms ease;
  }

  .note-card:hover,
  .note-card:focus-within {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lift);
  }

  .note-link {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    color: inherit;
  }

  .note-meta {
    font-size: var(--step-small);
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }

  .note-read {
    margin-left: 0.35rem;
  }

  .note-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
    text-wrap: balance;
    transition: color 160ms ease;
  }

  .note-card:hover .note-title,
  .note-card:focus-within .note-title {
    color: var(--leaf);
  }

  .note-desc {
    color: var(--muted);
    font-size: 0.975rem;
    line-height: 1.55;
  }

  .note-tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 1rem 0 0;
    padding: 0;
  }

  .note-tag {
    display: inline-flex;
    align-items: center;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.35rem 0.85rem;
    font-size: var(--step-small);
    font-weight: 600;
    color: var(--ink);
    text-decoration: none;
    transition: background 160ms ease, color 160ms ease, border-color 160ms ease;
  }

  .note-tag:hover {
    background: var(--moss);
    color: var(--leaf);
    border-color: var(--leaf);
  }
</style>
