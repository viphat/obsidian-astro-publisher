---
import { getTagPath } from "../lib/slug";

type Props = {
  createdAt: string;
  updatedAt: string;
  tags?: string[];
};

const { createdAt, updatedAt, tags = [] } = Astro.props;
---

<div class="note-meta">
  <span>Created {createdAt}</span>
  <span>Updated {updatedAt}</span>
  {tags.map((tag) => <a href={getTagPath(tag)}>#{tag}</a>)}
</div>
