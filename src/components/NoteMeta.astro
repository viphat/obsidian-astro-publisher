---
type Props = {
  createdAt: string;
  updatedAt: string;
  readMinutes?: number;
};

const { createdAt, updatedAt, readMinutes } = Astro.props;
const wasUpdated = updatedAt !== createdAt;
---

<div class="note-meta">
  <time datetime={createdAt}>{createdAt}</time>
  {wasUpdated && <span>· updated {updatedAt}</span>}
  {readMinutes !== undefined && <span>· {readMinutes} min read</span>}
</div>

<style>
  .note-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.75rem;
    font-family: var(--font-body);
    font-size: var(--step-small);
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }
</style>
