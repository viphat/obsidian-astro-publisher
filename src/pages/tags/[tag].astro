---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import NoteCard from "../../components/NoteCard.astro";
import { getPublicNotes, getTagGroups, sortNotesNewestFirst } from "../../lib/notes";
import { getPublicPathForSlug } from "../../lib/slug";

export async function getStaticPaths() {
  const notes = getPublicNotes(await getCollection("notes"));
  return getTagGroups(notes).map((group) => ({
    params: { tag: group.slug },
    props: { tag: group.label, notes: sortNotesNewestFirst(group.notes) }
  }));
}

const { tag, notes } = Astro.props;
---

<BaseLayout title={`#${tag} | Dương Đào Notes`} pathname={`/tags/${tag}`} variant="list">
  <header class="tag-header">
    <p class="tag-back"><a href="/">← All notes</a></p>
    <h1 class="tag-title"><span class="tag-hash">#</span>{tag}</h1>
    <p class="tag-count">
      {notes.length} {notes.length === 1 ? "note" : "notes"}
    </p>
  </header>
  <ol class="note-index">
    {notes.map((note) => (
      <NoteCard
        title={note.data.title}
        description={note.data.description}
        href={getPublicPathForSlug(note.data.slug)}
        updatedAt={note.data.updated_at}
        tags={note.data.tags}
      />
    ))}
  </ol>
</BaseLayout>

<style>
  .tag-header {
    margin-bottom: 0.5rem;
  }

  .tag-back {
    margin: 0 0 1rem;
    font-size: var(--step-small);
    font-weight: 600;
  }

  .tag-back a {
    color: var(--leaf);
    text-decoration: none;
  }

  .tag-back a:hover {
    color: var(--pine);
  }

  .tag-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--step-h1);
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin: 0;
  }

  .tag-hash {
    color: var(--leaf);
  }

  .tag-count {
    margin: 0.5rem 0 0;
    font-size: var(--step-small);
    color: var(--muted);
  }

  .note-index {
    list-style: none;
    display: grid;
    gap: 1rem;
    margin: 1.5rem 0 0;
    padding: 0;
  }
</style>
