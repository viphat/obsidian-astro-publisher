---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import NoteCard from "../components/NoteCard.astro";
import { getPublicPathForSlug } from "../lib/slug";
import { getPublicNotes, sortNotesNewestFirst } from "../lib/notes";

const notes = sortNotesNewestFirst(getPublicNotes(await getCollection("notes")));
---

<BaseLayout title="Duong Dao Notes" pathname="/" variant="list">
  <p class="index-lead">
    {notes.length} {notes.length === 1 ? "note" : "notes"}, newest first
  </p>
  {notes.length > 0 ? (
    <ol class="note-index">
      {notes.map((note) => (
        <NoteCard
          title={note.data.title}
          description={note.data.description}
          href={getPublicPathForSlug(note.data.slug)}
          updatedAt={note.data.updated_at}
          tags={note.data.tags}
        />
      ))}
    </ol>
  ) : (
    <p class="index-empty">No notes published yet. Check back soon.</p>
  )}
</BaseLayout>

<style>
  .index-lead {
    margin: 0 0 0.25rem;
    font-family: var(--font-mono);
    font-size: var(--step-small);
    color: var(--ink-faint);
    text-transform: lowercase;
  }

  .note-index {
    list-style: none;
    margin: 0;
    padding: 0;
    border-bottom: 1px solid var(--rule);
  }

  .index-empty {
    margin-top: 2rem;
    color: var(--ink-soft);
  }
</style>
